# Driv.in
DRIVIN_API_KEY=tu_api_key_aqui
DRIVIN_BASE_URL=https://external.driv.in/api/external/v2

# Mapbox (clave pública, se puede exponer al frontend)
MAPBOX_TOKEN=tu_token_mapbox_aqui

# Base de datos (PostgreSQL)
DATABASE_URL=postgresql://usuario:password@localhost:5432/andesmar_geo

# SQLite (fallback si no hay PostgreSQL disponible)
USE_SQLITE=true
SQLITE_PATH=./andesmar_geo.sqlite

# JWT
JWT_SECRET=cambiar_por_string_seguro_largo_al_menos_32_caracteres
JWT_EXPIRES_IN=8h

# Servidor
PORT=3000
NODE_ENV=development

# CORS - origen permitido para el frontend
FRONTEND_URL=http://localhost:8080
